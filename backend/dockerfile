

# ── Stage 1: deps ──────────────────────────────────────────────
FROM node:24.14.1-slim AS deps

RUN apt-get update -y \
    && apt-get install -y --no-install-recommends openssl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package*.json ./
RUN npm ci --omit=dev


# ── Stage 2: builder (generates Prisma client) ─────────────────
FROM node:24.14.1-slim AS builder

RUN apt-get update -y \
    && apt-get install -y --no-install-recommends openssl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY package*.json ./
COPY prisma ./prisma

RUN npm ci
RUN npx prisma generate


# ── Stage 3: test stage ────────────────────────────────────────

FROM node:24.14.1-slim AS test

RUN apt-get update -y \
    && apt-get install -y --no-install-recommends openssl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app



COPY package*.json ./
RUN npm ci --include=dev
# Prisma client is needed for tests that import it, so we generate it here as well.
# Copy generated Prisma client from builder stage.DRY principle: we don't want to repeat the prisma generate step in this test stage, so we copy the already generated client from the builder stage. This keeps our test stage lean and fast.
COPY --from=builder /app/node_modules/.prisma ./node_modules/.prisma
COPY . .

CMD ["npm", "test"]


# ── Stage 4: final image (runner) ──────────────────────────────
FROM node:24.14.1-slim AS runner

RUN apt-get update -y \
    && apt-get install -y --no-install-recommends openssl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Create non-root user
RUN addgroup --system appgroup && adduser --system --ingroup appgroup appuser

# Copy node_modules from deps stage (production deps only)
COPY --from=deps /app/node_modules ./node_modules

# Copy generated Prisma client from builder stage
COPY --from=builder /app/node_modules/.prisma ./node_modules/.prisma

# Copy the rest of the source code
COPY . .

# Give ownership to non-root user
RUN chown -R appuser:appgroup /app

# Set npm cache directory with proper permissions
# EACCESS denied, path:/nonexistent is a common npm error when running as non-root without a writable cache directory. Setting it to a directory owned by appuser prevents this.
RUN mkdir -p /home/appuser/.npm && chown -R appuser:appgroup /home/appuser

USER appuser

EXPOSE 5000

CMD ["node", "src/index.js"]





